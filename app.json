{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "eu.voltie.homey",
  "version": "1.0.0",
  "compatibility": ">=12.13.0",
  "sdk": 3,
  "runtime": "nodejs",
  "platforms": [
    "local"
  ],
  "name": {
    "en": "Voltie"
  },
  "description": {
    "en": "Smarter charging. Lower costs. Greener energy."
  },
  "category": [
    "energy"
  ],
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "Andras Heszegi",
    "email": "heszegi@gmail.com"
  },
  "brandColor": "#528AC8",
  "tags": {
    "en": [
      "ev; charger; home charging; energy;"
    ]
  },
  "homepage": "https://www.voltie.eu",
  "contributors": {
    "developers": [
      {
        "name": "András Heszegi"
      }
    ]
  },
  "source": "https://github.com/voltie-eu/homey-voltie_charger",
  "support": "mailto:info@voltie.eu",
  "bugs": {
    "url": "https://github.com/voltie-eu/homey-voltie_charger/issues"
  },
  "flow": {
    "triggers": [
      {
        "id": "current_limit_changed",
        "title": {
          "en": "Current limit changed"
        },
        "tokens": [
          {
            "name": "current_limit",
            "title": {
              "en": "Current limit"
            },
            "type": "number",
            "example": "6"
          }
        ],
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=voltie-charger"
          }
        ]
      },
      {
        "id": "autostart_changed",
        "title": {
          "en": "Auto Start changed"
        },
        "tokens": [
          {
            "name": "autostart",
            "title": {
              "en": "Auto Start"
            },
            "type": "boolean",
            "example": true
          }
        ],
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=voltie-charger"
          }
        ]
      }
    ],
    "conditions": [
      {
        "id": "autostart",
        "title": {
          "en": "Auto Start is turned !{{on|off}}"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=voltie-charger"
          }
        ]
      }
    ],
    "actions": [
      {
        "id": "set_current_limit",
        "title": {
          "en": "Set current limit to..."
        },
        "titleFormatted": {
          "en": "Set current limit to [[current_limit]]A"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=voltie-charger"
          },
          {
            "type": "number",
            "name": "current_limit",
            "title": {
              "en": "Current limit"
            },
            "min": 6,
            "max": 32,
            "step": 1
          }
        ]
      },
      {
        "id": "set_autostart",
        "title": {
          "en": "Set Auto Start to..."
        },
        "titleFormatted": {
          "en": "Set Auto Start to [[autostart]]"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=voltie-charger"
          },
          {
            "type": "dropdown",
            "name": "autostart",
            "title": {
              "en": "On/Off"
            },
            "values": [
              {
                "id": "true",
                "title": {
                  "en": "On"
                }
              },
              {
                "id": "false",
                "title": {
                  "en": "Off"
                }
              }
            ]
          }
        ]
      }
    ]
  },
  "drivers": [
    {
      "name": {
        "en": "Voltie Charger"
      },
      "class": "evcharger",
      "capabilities": [
        "evcharger_charging",
        "autostart",
        "evcharger_charging_state",
        "phase",
        "charging_time",
        "meter_power",
        "measure_power",
        "measure_current",
        "current_limit"
      ],
      "capabilitiesOptions": {
        "meter_power": {
          "title": {
            "en": "Energy charged"
          }
        },
        "measure_power": {
          "title": {
            "en": "Charging Power"
          }
        },
        "measure_current": {
          "title": {
            "en": "Charging Current"
          }
        }
      },
      "energy": {
        "evCharger": true,
        "meterPowerImportedCapability": "meter_power"
      },
      "platforms": [
        "local"
      ],
      "connectivity": [
        "lan"
      ],
      "discovery": "voltie_discovery",
      "icon": "/drivers/voltie-charger/assets/icon.svg",
      "images": {
        "small": "/drivers/voltie-charger/assets/images/small.png",
        "large": "/drivers/voltie-charger/assets/images/large.png",
        "xlarge": "/drivers/voltie-charger/assets/images/xlarge.png"
      },
      "pair": [
        {
          "id": "choose_pairing"
        },
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "setup_device"
          },
          "options": {
            "singular": true
          }
        },
        {
          "id": "setup_device"
        }
      ],
      "id": "voltie-charger",
      "settings": [
        {
          "id": "ip",
          "type": "text",
          "value": "",
          "label": {
            "en": "IP Address"
          },
          "hint": {
            "en": "The IP address of Your Voltie charger"
          }
        },
        {
          "id": "port",
          "type": "text",
          "value": "",
          "label": {
            "en": "Port"
          },
          "hint": {
            "en": "The port of Your Voltie charger (default: 5059)"
          }
        },
        {
          "id": "maxCurrentLimit",
          "type": "text",
          "value": "",
          "label": {
            "en": "Maximum Current Limit"
          },
          "hint": {
            "en": "The maximum current limit for your Voltie charger, be careful not to exceed the installation's capabilities!"
          }
        },
        {
          "id": "username",
          "type": "text",
          "value": "",
          "label": {
            "en": "Username"
          },
          "hint": {
            "en": "The username for your Voltie charger (if applicable)"
          }
        },
        {
          "id": "password",
          "type": "password",
          "value": "",
          "label": {
            "en": "Password"
          },
          "hint": {
            "en": "The password for your Voltie charger (if applicable)"
          }
        }
      ]
    }
  ],
  "capabilities": {
    "autostart": {
      "type": "boolean",
      "getable": true,
      "setable": true,
      "uiComponent": "toggle",
      "title": {
        "en": "Auto Start"
      }
    },
    "charging_time": {
      "type": "string",
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "title": {
        "en": "Charging Time"
      },
      "icon": "/drivers/voltie-charger/assets/icons/charging_time.svg"
    },
    "current_limit": {
      "type": "enum",
      "title": {
        "en": "Charging Current Limit"
      },
      "values": [],
      "getable": true,
      "setable": true,
      "uiComponent": "picker"
    },
    "phase": {
      "type": "number",
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "title": {
        "en": "Number of Phases"
      },
      "icon": "/drivers/voltie-charger/assets/icons/phase.svg"
    }
  },
  "discovery": {
    "voltie_discovery": {
      "type": "mdns-sd",
      "mdns-sd": {
        "name": "voltie-info",
        "protocol": "tcp"
      },
      "id": "{{host}}"
    }
  }
}