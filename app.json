    "actions": [
      {
        "id": "set_current_limit",
        "title": {
          "en": "Set 'Current Limit' to ..."
        },
        "titleFormatted": {
          "en": "Set 'Current Limit' to [[current_limit]]A"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=voltie-charger"
          },
          {
            "type": "number",
            "name": "current_limit",
            "title": {
              "en": "Current Limit"
            },
            "min": 6,
            "max": 32,
            "step": 1
          }
        ]
      },
      {
        "id": "set_autostart",
        "title": {
          "en": "Set 'Auto Start' to ..."
