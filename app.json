  "drivers": [
    {
      "name": {
        "en": "Voltie Charger"
      },
      "class": "evcharger",
      "capabilities": [
        "evcharger_charging",
        "front_led",
        "rear_led",
        "autostart",
        "force_single_phase",
        "current_limit",
        "evcharger_charging_state",
        "active_phases",
        "charging_time",
        "meter_power",
        "measure_power",
        "measure_current"
      ],
      "capabilitiesOptions": {
        "meter_power": {
          "title": {
            "en": "Energy Charged"
          }
        },
        "measure_power": {
          "title": {
            "en": "Charging Power"
          }
        },
        "measure_current": {
          "title": {
            "en": "Charging Current"
          }
        }
      },
      "energy": {
        "evCharger": true,
        "meterPowerImportedCapability": "meter_power"
      },
      "platforms": [
        "local"
      ],
      "connectivity": [
        "lan"
      ],
      "discovery": "voltie_discovery",
      "icon": "/drivers/voltie-charger/assets/icon.svg",
      "images": {
        "small": "/drivers/voltie-charger/assets/images/small.png",
        "large": "/drivers/voltie-charger/assets/images/large.png",
        "xlarge": "/drivers/voltie-charger/assets/images/xlarge.png"
      },
      "pair": [
        {
          "id": "choose_pairing"
        },
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "setup_device"
          },
          "options": {
            "singular": true
          }
        },
        {
          "id": "setup_device"
        }
      ],
      "id": "voltie-charger",
      "settings": [
        {
          "id": "ip",
          "type": "text",
          "value": "",
          "label": {
            "en": "IP Address"
          },
          "hint": {
            "en": "The IP address of Your Voltie charger"
          }
        },
        {
          "id": "port",
          "type": "text",
          "value": "",
          "label": {
            "en": "Port"
          },
          "hint": {
            "en": "The port of Your Voltie charger (default: 5059)"
          }
        },
        {
          "id": "maxCurrentLimit",
          "type": "text",
          "value": "",
          "label": {
            "en": "Maximum current limit"
          },
          "hint": {
            "en": "The maximum charging current limit for your Voltie charger, the hardware limit will override this if it is lower!"
          }
        },
        {
          "id": "username",
          "type": "text",
          "value": "",
          "label": {
            "en": "Username"
          },
          "hint": {
            "en": "The username for your Voltie charger (if applicable)"
          }
        },
        {
          "id": "password",
          "type": "password",
          "value": "",
          "label": {
            "en": "Password"
          },
          "hint": {
            "en": "The password for your Voltie charger (if applicable)"
          }
        }
      ]
    }
  ],
  "capabilities": {
    "active_phases": {
