        "titleFormatted": {
          "en": "Set 'Auto Start' to [[autostart]]"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=voltie-charger"
          },
          {
            "type": "dropdown",
            "name": "autostart",
            "title": {
              "en": "On/Off"
            },
            "values": [
              {
                "id": "true",
                "title": {
                  "en": "On"
                }
              },
              {
                "id": "false",
                "title": {
                  "en": "Off"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "set_force_single_phase",
        "title": {
          "en": "Set 'Force Single Phase' to ..."
