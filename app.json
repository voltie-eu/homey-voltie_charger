      "setable": true,
      "uiComponent": "picker"
    },
    "force_single_phase": {
      "type": "boolean",
      "title": {
        "en": "Force Single Phase"
      },
      "getable": true,
      "setable": true,
      "uiComponent": "button",
      "icon": "/drivers/voltie-charger/assets/icons/phase.svg"
    },
    "front_led": {
      "type": "boolean",
      "title": {
        "en": "Front LED Enabled"
      },
      "getable": true,
      "setable": true,
      "uiComponent": "button",
      "icon": "/drivers/voltie-charger/assets/icons/led.svg"
    },
    "rear_led": {
      "type": "boolean",
      "title": {
