{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "com.heszi.voltie",
  "version": "1.0.0",
  "compatibility": ">=12.5.0",
  "sdk": 3,
  "runtime": "nodejs",
  "platforms": [
    "local"
  ],
  "name": {
    "en": "Voltie"
  },
  "description": {
    "en": "Smarter charging. Lower costs. Greener energy."
  },
  "category": [
    "energy"
  ],
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "Andras Heszegi",
    "email": "heszegi@gmail.com"
  },
  "brandColor": "#528AC8",
  "tags": {
    "en": [
      "ev; charger; home charging; energy;"
    ]
  },
  "homepage": "https://www.voltie.eu",
  "contributors": {
    "developers": []
  },
  "drivers": [
    {
      "name": {
        "en": "Voltie Charger"
      },
      "class": "evcharger",
      "capabilities": [
        "evcharger_charging",
        "evcharger_charging_state",
        "measure_power",
        "meter_power"
      ],
      "energy": {
        "evCharger": true,
        "meterPowerImportedCapability": "meter_power"
      },
      "platforms": [
        "local"
      ],
      "connectivity": [
        "lan"
      ],
      "discovery": "voltie_discovery",
      "icon": "/drivers/voltie-charger/assets/icon.svg",
      "images": {
        "small": "/drivers/voltie-charger/assets/images/small.png",
        "large": "/drivers/voltie-charger/assets/images/large.png",
        "xlarge": "/drivers/voltie-charger/assets/images/xlarge.png"
      },
      "pair": [
        {
          "id": "choose_pairing"
        },
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "setup_device"
          },
          "options": {
            "singular": true
          }
        },
        {
          "id": "setup_device"
        }
      ],
      "id": "voltie-charger",
      "settings": [
        {
          "id": "ip",
          "type": "text",
          "value": "",
          "label": {
            "en": "IP Address"
          },
          "hint": {
            "en": "The IP address of Your Voltie charger"
          }
        },
        {
          "id": "port",
          "type": "text",
          "value": "",
          "label": {
            "en": "Port"
          },
          "hint": {
            "en": "The port of Your Voltie charger"
          }
        },
        {
          "id": "username",
          "type": "text",
          "value": "",
          "label": {
            "en": "Username"
          },
          "hint": {
            "en": "The username for your Voltie charger (if applicable)"
          }
        },
        {
          "id": "password",
          "type": "password",
          "value": "",
          "label": {
            "en": "Password"
          },
          "hint": {
            "en": "The password for your Voltie charger (if applicable)"
          }
        }
      ]
    }
  ],
  "discovery": {
    "voltie_discovery": {
      "type": "mdns-sd",
      "mdns-sd": {
        "name": "voltie-info",
        "protocol": "tcp"
      },
      "id": "{{host}}"
    }
  }
}