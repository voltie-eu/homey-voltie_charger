{
  "_comment": "This file is generated. Please edit .homeycompose/app.json instead.",
  "id": "eu.voltie.homey",
  "version": "1.0.0",
  "compatibility": ">=12.13.0",
  "sdk": 3,
  "runtime": "nodejs",
  "platforms": [
    "local"
  ],
  "name": {
    "en": "Voltie"
  },
  "description": {
    "en": "Smarter charging. Lower costs. Greener energy."
  },
  "category": [
    "energy"
  ],
  "permissions": [],
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "Andras Heszegi",
    "email": "heszegi@gmail.com"
  },
  "brandColor": "#528AC8",
  "tags": {
    "en": [
      "ev; charger; home charging; energy;"
    ]
  },
  "homepage": "https://www.voltie.eu",
  "contributors": {
    "developers": [
      {
        "name": "András Heszegi"
      }
    ]
  },
  "source": "https://github.com/voltie-eu/homey-voltie_charger",
  "support": "mailto:info@voltie.eu",
  "bugs": {
    "url": "https://github.com/voltie-eu/homey-voltie_charger/issues"
  },
  "drivers": [
    {
      "name": {
        "en": "Voltie Charger"
      },
      "class": "evcharger",
      "capabilities": [
        "evcharger_charging",
        "autostart",
        "evcharger_charging_state",
        "meter_power",
        "measure_power",
        "measure_current",
        "current_limit"
      ],
      "energy": {
        "evCharger": true,
        "meterPowerImportedCapability": "meter_power"
      },
      "platforms": [
        "local"
      ],
      "connectivity": [
        "lan"
      ],
      "discovery": "voltie_discovery",
      "icon": "/drivers/voltie-charger/assets/icon.svg",
      "images": {
        "small": "/drivers/voltie-charger/assets/images/small.png",
        "large": "/drivers/voltie-charger/assets/images/large.png",
        "xlarge": "/drivers/voltie-charger/assets/images/xlarge.png"
      },
      "pair": [
        {
          "id": "choose_pairing"
        },
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "setup_device"
          },
          "options": {
            "singular": true
          }
        },
        {
          "id": "setup_device"
        }
      ],
      "id": "voltie-charger",
      "settings": [
        {
          "id": "ip",
          "type": "text",
          "value": "",
          "label": {
            "en": "IP Address"
          },
          "hint": {
            "en": "The IP address of Your Voltie charger"
          }
        },
        {
          "id": "port",
          "type": "text",
          "value": "",
          "label": {
            "en": "Port"
          },
          "hint": {
            "en": "The port of Your Voltie charger"
          }
        },
        {
          "id": "maxCurrentLimit",
          "type": "text",
          "value": "",
          "label": {
            "en": "Maximum Current Limit"
          },
          "hint": {
            "en": "The maximum current limit for your Voltie charger, be careful not to exceed the installation's capabilities!"
          }
        },
        {
          "id": "username",
          "type": "text",
          "value": "",
          "label": {
            "en": "Username"
          },
          "hint": {
            "en": "The username for your Voltie charger (if applicable)"
          }
        },
        {
          "id": "password",
          "type": "password",
          "value": "",
          "label": {
            "en": "Password"
          },
          "hint": {
            "en": "The password for your Voltie charger (if applicable)"
          }
        }
      ]
    }
  ],
  "capabilities": {
    "autostart": {
      "type": "boolean",
      "getable": true,
      "setable": true,
      "uiComponent": "toggle",
      "title": {
        "en": "Auto Start"
      }
    },
    "current_limit": {
      "type": "enum",
      "title": {
        "en": "Charging Current Limit"
      },
      "values": [],
      "getable": true,
      "setable": true,
      "uiComponent": "picker"
    }
  },
  "discovery": {
    "voltie_discovery": {
      "type": "mdns-sd",
      "mdns-sd": {
        "name": "voltie-info",
        "protocol": "tcp"
      },
      "id": "{{host}}"
    }
  }
}