        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=voltie-charger"
          },
          {
            "type": "dropdown",
            "name": "force_single_phase",
            "title": {
              "en": "On/Off"
            },
            "values": [
              {
                "id": "true",
                "title": {
                  "en": "On"
                }
              },
              {
                "id": "false",
                "title": {
                  "en": "Off"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "set_front_led",
        "title": {
          "en": "Set 'Front LED' to ..."
        },
        "titleFormatted": {
          "en": "Set 'Front LED' to [[front_led]]"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=voltie-charger"
          },
          {
            "type": "dropdown",
            "name": "front_led",
            "title": {
              "en": "On/Off"
