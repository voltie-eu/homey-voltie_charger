{
  "triggers": [
    {
      "id": "current_limit_changed",
      "title": {
          "en": "Current limit changed"
      },
      "tokens": [
        {
          "name": "current_limit",
          "title": { "en": "Current limit" },
          "type": "number",
          "example": "6"
        }
      ]
    },
    {
      "id": "autostart_changed",
      "title": {
          "en": "Auto Start changed"
      },
      "tokens": [
        {
          "name": "autostart",
          "title": { "en": "Auto Start" },
          "type": "boolean",
          "example": true
        }
      ]
    }
  ],
  "conditions": [
    {
      "id": "autostart",
      "title": {
          "en": "Auto Start is turned !{{on|off}}"
      }
    }
  ],
  "actions": [
    {
      "id": "set_current_limit",
      "title": {
          "en": "Set current limit to [[current_limit]]A"
      },
      "args": [
        {
          "type": "number",
          "name": "current_limit",
          "title": {
            "en": "Current limit"
          },
          "min": 6,
          "max": 32,
          "step": 1
        }
      ]
    },
    {
      "id": "set_autostart",
      "title": {
          "en": "Set Auto Start to [[autostart]]"
      },
      "args": [
        {
          "type": "dropdown",
          "name": "autostart",
          "title": {
            "en": "On/Off"
          },
          "values": [
            { "id": "true", "title": { "en": "On" } },
            { "id": "false", "title": { "en": "Off" } }
          ]
        }
      ]
    }
  ]
}
